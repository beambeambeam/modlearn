{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./auth/roles": {
      "default": "./src/lib/auth/roles.ts"
    },
    "./auth/*": {
      "default": "./src/lib/auth/*.ts"
    },
    "./db/*": {
      "default": "./src/lib/db/*.ts"
    },
    "./trpc": {
      "default": "./src/trpc/index.ts"
    },
    "./trpc/*": {
      "default": "./src/trpc/*.ts"
    }
  },
  "scripts": {
    "auth:generate": "bun x @better-auth/cli generate --config ./auth.ts --output ./src/lib/db/schema/auth.ts --yes",
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/lib/db/seed.ts",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/trpc": "^1.1.0",
    "@hono/trpc-server": "^0.4.0",
    "@modlearn/env": "workspace:*",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "elysia": "catalog:",
    "pg": "^8.17.1",
    "trpc-docs-generator": "^0.6.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth/cli": "catalog:",
    "@modlearn/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^2.0.5",
    "@vitest/ui": "^2.0.5",
    "aws-sdk-client-mock": "^4.1.0",
    "drizzle-kit": "^0.31.8",
    "tsdown": "^0.16.5",
    "typescript": "catalog:",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.0.5"
  }
}
